{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Canonical Event",
  "type": "object",

  "required": [
    "id",
    "actor",
    "timestamp",
    "type",
    "body"
  ],

  "properties": {
    "id": {
      "type": "string"
    },

    "actor": {
      "type": "string"
    },

    "timestamp": {
      "type": "integer"
    },

    "type": {
      "type": "string"
    },

    "body": {
      "type": "object"
    },

    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },

    "signatures": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },

    "metadata": {
      "type": "object"
    }
  }
}